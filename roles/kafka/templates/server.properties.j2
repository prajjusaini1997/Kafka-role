#############################################
# Kafka Broker ID
#############################################

broker.id={{ broker_id }}

#############################################
# Listeners
#############################################

listeners=PLAINTEXT://:9092
advertised.listeners=PLAINTEXT://{{ private_ip_address }}:9092

#############################################
# Log Directory
#############################################

log.dirs=/var/lib/kafka-logs-{{ broker_id }}

#############################################
# ZooKeeper
#############################################

zookeeper.connect={% for host in groups['tag_kafka'] %}{% if hostvars[host]['tags']['Name'] == 'Kafka-Broker-1' %}{{ hostvars[host]['private_ip_address'] }}{% endif %}{% endfor %}:2181

#############################################
# Topic Settings
#############################################

num.partitions=3
default.replication.factor=3
offsets.topic.replication.factor=3
transaction.state.log.replication.factor=3
transaction.state.log.min.isr=2

#############################################
# Network Threads
#############################################

num.network.threads=3
num.io.threads=8

#############################################
# Socket Buffers
#############################################

socket.send.buffer.bytes=102400
socket.receive.buffer.bytes=102400
socket.request.max.bytes=104857600

#############################################
# Log Retention
#############################################

log.retention.hours=168
log.segment.bytes=1073741824
log.retention.check.interval.ms=300000

#############################################
# Internal Topics
#############################################

min.insync.replicas=2
delete.topic.enable=true
auto.create.topics.enable=true

#############################################
# Group Coordinator
#############################################

group.initial.rebalance.delay.ms=0
